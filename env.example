# ============================================================
# Canvas LMS on Klutch — environment variables
# Copy values into your Klutch app's "Environment" panel.
# Never commit a real .env file.
# ============================================================

# --- Public hostname (the *.klutch.sh URL Klutch assigns your app) ---
CANVAS_DOMAIN=tilburgcanvas.klutch.sh

# --- Klutch Postgres add-on ---
# Get these from: Klutch project → Add-ons → Postgres → Connection details
DATABASE_HOST=postgres-internal-host.klutch.internal
DATABASE_PORT=5432
DATABASE_NAME=canvas
DATABASE_USER=canvas
DATABASE_PASSWORD=replace-me
DATABASE_POOL=20

# --- Klutch Redis add-on ---
# Format: redis://:password@host:6379
REDIS_URL=redis://:replace-me@redis-internal-host.klutch.internal:6379

# --- Secrets (generate with: openssl rand -hex 64 / -hex 32) ---
SECRET_KEY_BASE=generate-with-openssl-rand-hex-64
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# --- SMTP (optional, leave blank to disable email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=plain
SMTP_FROM=no-reply@tilburgcanvas.klutch.sh

# --- Rails ---
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
